# ── Sentry ──────────────────────────────────────────────────────────────────
# Get your DSN from: Sentry dashboard → Settings → Projects → your project → Client Keys
VITE_SENTRY_DSN=

# App version injected into Sentry releases (defaults to 1.1.0 if not set)
VITE_APP_VERSION=1.1.0

# Required for source map uploads during production builds (npm run build).
# Generate at: https://sentry.io/settings/auth-tokens/
# Needs scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
